# HubSpot Private App token
# Create at: HubSpot → Settings → Integrations → Private Apps
# Required scope: crm.objects.contacts.write  (nothing else needed)
HUBSPOT_API_KEY=your_hubspot_private_app_token

# Resend API key  https://resend.com/api-keys
# NOTE: verify zyflux.com domain in Resend before deploying
# Resend → Domains → Add Domain → add the DNS records for zyflux.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Optional — defaults to team@zyflux.com
# NOTIFY_EMAIL=team@zyflux.com
